# ─── API Configuration ────────────────────────────────────────────────────────
# In Docker: nginx proxies /api to mes:8080, so keep /api/v1
# In local dev: Vite proxy forwards /api to localhost:8080
VITE_API_URL=/api/v1

# ─── Application ─────────────────────────────────────────────────────────────
VITE_APP_NAME=MES Platform
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Manufacturing Execution System

# ─── Feature Flags ───────────────────────────────────────────────────────────
VITE_ENABLE_SSE=true
VITE_ENABLE_DEVTOOLS=false
VITE_ENABLE_MOCK=false

# ─── SSE / Realtime ──────────────────────────────────────────────────────────
VITE_SSE_ENDPOINT=/api/v1/projection/stream
VITE_SSE_RECONNECT_DELAY_MS=3000
VITE_SSE_HEARTBEAT_TIMEOUT_MS=45000

# ─── Pagination Defaults ─────────────────────────────────────────────────────
VITE_DEFAULT_PAGE_SIZE=25
VITE_MAX_PAGE_SIZE=100

# ─── Query Stale Times (ms) ──────────────────────────────────────────────────
VITE_QUERY_STALE_TIME=300000
VITE_QUERY_REFETCH_INTERVAL=30000
