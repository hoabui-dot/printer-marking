{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "MQTTnet": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=device-simulator-dev.db",
    "Redis": "localhost:6379"
  },
  "Simulator": {
    "MQTT_HOST": "localhost",
    "GATEWAY_AUTO_PUBLISH_ENABLED": "true",
    "GATEWAY_AUTO_PUBLISH_INTERVAL_SEC": "15"
  }
}
