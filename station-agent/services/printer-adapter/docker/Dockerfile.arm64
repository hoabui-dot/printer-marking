# syntax=docker/dockerfile:1
# ARM64 cross-compilation: build runs on host (amd64), cross-compiles for arm64.

# Stage 1 — restore: cached unless .csproj files change
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:10.0 AS restore
ARG TARGETARCH=arm64
WORKDIR /src
ENV DOTNET_CLI_TELEMETRY_OPTOUT=1 DOTNET_GCConserveMemory=9
COPY Directory.Build.props ./
COPY Directory.Packages.props ./
COPY station-agent.sln ./
COPY shared/ shared/
COPY services/printer-adapter/src/ND.PrinterAdapter.Api/ND.PrinterAdapter.Api.csproj \
     services/printer-adapter/src/ND.PrinterAdapter.Api/
COPY services/printer-adapter/src/ND.PrinterAdapter.Application/ND.PrinterAdapter.Application.csproj \
     services/printer-adapter/src/ND.PrinterAdapter.Application/
COPY services/printer-adapter/src/ND.PrinterAdapter.Domain/ND.PrinterAdapter.Domain.csproj \
     services/printer-adapter/src/ND.PrinterAdapter.Domain/
COPY services/printer-adapter/src/ND.PrinterAdapter.Infrastructure/ND.PrinterAdapter.Infrastructure.csproj \
     services/printer-adapter/src/ND.PrinterAdapter.Infrastructure/
RUN dotnet restore services/printer-adapter/src/ND.PrinterAdapter.Api/ND.PrinterAdapter.Api.csproj \
    -a $TARGETARCH

# Stage 2 — publish (cross-compile for arm64)
FROM restore AS build
COPY services/printer-adapter/ services/printer-adapter/
RUN dotnet publish services/printer-adapter/src/ND.PrinterAdapter.Api/ND.PrinterAdapter.Api.csproj \
    -c Release -o /app/publish --no-restore -a $TARGETARCH \
    /p:UseSharedCompilation=false /p:ConcurrentBuild=false

# Stage 3 — runtime
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
USER root
RUN apt-get update && apt-get install -y cups-client cups-bsd socat && rm -rf /var/lib/apt/lists/*
USER app
COPY --chown=app:app --from=build /app/publish .
VOLUME ["/data", "/logs"]
EXPOSE 5003
ENV ASPNETCORE_URLS=http://+:5003 \
    CUPS_SERVER=127.0.0.1:8631 \
    CUPS_USER=root
ENTRYPOINT ["/bin/bash", "-c", "socat TCP-LISTEN:8631,fork,bind=127.0.0.1 TCP:host.docker.internal:631 & exec dotnet ND.PrinterAdapter.Api.dll"]
